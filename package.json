{
  "name": "kinetik-engine",
  "version": "0.1.7",
  "description": "Kinetik engine and project initializer for Three.js games",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json",
    "./init.js": "./init.js",
    "./globals.js": "./globals.js",
    "./platform.js": "./platform.js",
    "./scene.js": "./scene.js",
    "./input.js": "./input.js",
    "./physics.js": "./physics.js",
    "./stateManager.js": "./stateManager.js",
    "./saveManager.js": "./saveManager.js",
    "./levelLoader.js": "./levelLoader.js",
    "./mobileControls.js": "./mobileControls.js",
    "./settings.js": "./settings.js",
    "./networking.js": "./networking.js",
    "./playerProfile.js": "./playerProfile.js",
    "./uvDebug.js": "./uvDebug.js",
    "./ccd-ik.js": "./ccd-ik.js",
    "./three-ik.js": "./three-ik.js",
    "./scriptManager.js": "./scriptManager.js",
    "./editor.js": "./editor.js",
    "./game/bootstrap.js": "./scaffold/src/game/bootstrap.js",
    "./game/globals.js": "./scaffold/src/game/globals.js",
    "./game/ground.js": "./scaffold/src/game/ground.js",
    "./game/player.js": "./scaffold/src/game/player.js"
  },
  "bin": {
    "kinetik": "./bin/create-kinetik-app.js",
    "create-kinetik-app": "./bin/create-kinetik-app.js"
  },
  "files": [
    "*.js",
    "scripts/**/*",
    "bin/**/*",
    "scaffold/**/*",
    "scaffold/.gitignore",
    "README.md"
  ],
  "scripts": {
    "init": "node init.js",
    "postinstall": "node sync-generated-editor-html.js"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "three": "^0.163.0",
    "three-bvh-csg": "^0.0.17",
    "three-mesh-bvh": "^0.6.8"
  }
}
